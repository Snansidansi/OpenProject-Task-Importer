{
  "name": "OpenProject Task Importer",
  "description": "An extension to import Tasks from a PDF file into OpenProject using a OpenRouter LLM.",
  "version": "1.0.0",
  "manifest_version": 3,
  "default_locale": "en",
  "action": {
    "default_popup": "index.html"
  },
  "background": {
    "service_worker": "src/background.ts",
    "type": "module"
  },
  "permissions": ["storage"],
  "host_permissions": ["http://*/*", "https://*/*", "http://localhost/*", "http://127.0.0.1/*"]
}
